POSTGRES_DB=laudoia
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

APP_NAME=LaudoIA Pericial API
APP_ENV=development
APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ADMIN_EMAILS=admin@example.com
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/laudoia
UPLOAD_DIR=storage/uploads
REPORT_TEMPLATE_PATH=app/assets/report_template.docx
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_URL=http://localhost:8000/api/v1/billing/webhooks/mercado-pago

OPENROUTER_API_KEY=
